# ─────────────────────────────────────────────────────────────────────
# NeuroShield Environment Variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────

# --- Kafka ---
KAFKA_BOOTSTRAP=kafka:9092

# --- PostgreSQL ---
DATABASE_URL=postgresql://ns_user:ns_pass@postgres:5432/neuroshield

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- Ingestion ---
INGESTION_MODE=all           # 'pcap' | 'netflow' | 'bank_portal' | 'all'
DATA_DIR=/data/pcap

# --- Feature Engine ---
FLOW_TIMEOUT_SECONDS=3

# --- Inference / Decision Engine ---
MODEL_PATH=/models
SANDBOX_CONFIDENCE_THRESHOLD=0.50  # confidence >= this → sandbox

# --- Sandbox ---
SANDBOX_TIMEOUT_SEC=300

# --- Retraining ---
RETRAIN_BATCH_SIZE=500       # number of feedback samples before retraining triggers

# --- Reporting ---
REPORT_EMAIL=analyst@yourorg.com
REPORT_TIME=06:00
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=neuroshield@yourorg.com
SMTP_PASS=changeme

# --- Alerting ---
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- Frontend ---
VITE_API_URL=http://localhost:8000
